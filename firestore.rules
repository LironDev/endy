rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{gameId} {
      // Any authenticated user (incl. anonymous) can read a game
      allow read: if request.auth != null;

      // Create: must be authenticated, must be the host, status must be 'lobby'
      allow create: if request.auth != null
        && request.resource.data.config.hostId == request.auth.uid
        && request.resource.data.status == 'lobby';

      // Update is allowed in two scenarios:
      allow update: if request.auth != null
        && (
          // ── Scenario A: Normal gameplay (game is NOT ended) ──────────────
          (
            resource.data.status != 'ended'
            && (
              // Existing player updating any game state
              request.auth.uid in resource.data.players
              ||
              // New player joining the lobby (only adding their own uid to players)
              (
                resource.data.status == 'lobby'
                && request.auth.uid in request.resource.data.players
                && !(request.auth.uid in resource.data.players)
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])
              )
            )
          )
          ||
          // ── Scenario B: Host resets an ended game back to lobby ──────────
          (
            resource.data.status == 'ended'
            && request.auth.uid == resource.data.config.hostId
          )
        );

      // Delete: host only
      allow delete: if request.auth != null
        && resource.data.config.hostId == request.auth.uid;
    }
  }
}
