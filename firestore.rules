rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{gameId} {
      // Any authenticated user (incl. anonymous) can read a game
      allow read: if request.auth != null;

      // Create: must be authenticated, must be the host, status must be 'lobby'
      allow create: if request.auth != null
        && request.resource.data.config.hostId == request.auth.uid
        && request.resource.data.status == 'lobby';

      // Update: authenticated + game not ended +
      //   (existing player updating state) OR (new player joining lobby)
      allow update: if request.auth != null
        && resource.data.status != 'ended'
        && (
          // Existing player is allowed to update any game state
          request.auth.uid in resource.data.players
          ||
          // New player joining the lobby (adding only their own uid to players)
          (
            resource.data.status == 'lobby'
            && request.auth.uid in request.resource.data.players
            && !(request.auth.uid in resource.data.players)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['players'])
          )
        );

      // Delete: host only (not currently exposed in UI but available for cleanup)
      allow delete: if request.auth != null
        && resource.data.config.hostId == request.auth.uid;
    }
  }
}
